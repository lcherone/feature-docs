{
  "siteName": "Soho Home",
  "baseUrl": "https://dev.soho-home.local",
  "publicBaseUrl": "https://sohohome.com",
  "startUrls": [
    "/"
  ],
  "outputDir": "docs",
  "codeDocs": {
    "enabled": true,
    "outputDir": "../code-docs"
  },
  "ignoreHTTPSErrors": true,
  "waitUntil": "networkidle",
  "readySelector": "body",
  "postNavigateWaitMs": 750,
  "timeoutMs": 45000,
  "auth": "anonymous",
  "extraHTTPHeaders": {},
  "cookies": [],
  "dismissText": [
    "Accept all cookies",
    "Accept and close",
    "Accept Cookies"
  ],
  "crawl": {
    "enabled": true,
    "maxPages": 20,
    "expandCrud": true,
    "dedupeDynamicRoutes": true,
    "discoverControllerActions": true,
    "linkSelector": "nav a, header a, footer a, .navigation a, .sidebar a, .menu a, [role=\"navigation\"] a",
    "includePatterns": [
      "^/"
    ],
    "excludePatterns": [
      "logout",
      "delete",
      "remove",
      "export",
      "download",
      "print",
      "impersonate",
      "action=",
      "token=",
      "\\.(pdf|zip|jpg|jpeg|png|gif|webp|svg)$"
    ]
  },
  "viewports": [
    {
      "name": "desktop",
      "width": 1440,
      "height": 1100,
      "fullPage": true
    }
  ],
  "maxFieldScreenshotsPerPage": 80,
  "fieldScreenshotPaddingPx": 8,
  "humanDocs": {
    "fieldDetailThreshold": 12,
    "maxKeyFields": 24,
    "maxInlineFieldScreenshots": 8,
    "maxVisibleOptions": 12,
    "includePageDetails": false,
    "includeFieldReference": false,
    "includeFieldTechnicalDetails": false,
    "includeTechnicalReferences": false,
    "includeReviewNotes": false
  },
  "codeAnalysis": {
    "enabled": true,
    "maxFileBytes": 60000,
    "providerGlobs": [
      "src/Provider.php",
      "src/*/Provider.php",
      "vendor/d3r/*/src/Provider.php",
      "vendor/d3r/*/src/*/Provider.php",
      "vendor/soho/*/src/Provider.php",
      "vendor/soho/*/src/*/Provider.php",
      "vendor/soho/ecom/src/Provider.php",
      "vendor/soho/products/src/Provider.php",
      "vendor/soho/ecom/src/*/Provider.php",
      "vendor/soho/products/src/*/Provider.php"
    ]
  }
}
